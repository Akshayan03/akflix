{
  "name": "akflix",
  "private": true,
  "version": "1.0.0",
  "description": "Standalone movie and series streaming app with optional Jellyfin integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --config src-tauri/tauri.local.conf.json",
    "tauri:build:signed": "tauri build",
    "icons": "tauri icon assets/icon.png",
    "build:mac": "tauri build --config src-tauri/tauri.local.conf.json --bundles app,dmg",
    "build:mac:universal": "node scripts/prepare-macos-sidecars.mjs && tauri build --config src-tauri/tauri.local.conf.json --target universal-apple-darwin --bundles app,dmg",
    "build:win": "tauri build --config src-tauri/tauri.local.conf.json --bundles msi,nsis",
    "build:linux": "tauri build --config src-tauri/tauri.local.conf.json --bundles deb,appimage",
    "updater:keygen": "tauri signer generate -w ~/.tauri/akflix.key",
    "website:dev": "npx serve website"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-http": "^2.0.1",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "framer-motion": "^11.11.17",
    "hls.js": "^1.5.17",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sonner": "^2.0.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
