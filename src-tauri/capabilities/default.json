{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Akflix window capabilities: CORS-free HTTP to media services, deep links, updater.",
  "windows": ["main"],
  "platforms": ["macOS", "windows", "linux"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "dialog:allow-open",
    "deep-link:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*" },
        { "url": "https://*:*" }
      ]
    }
  ]
}
